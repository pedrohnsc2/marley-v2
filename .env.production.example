# =============================================================================
# Marley Production Environment Variables
# Copy to .env.production and fill in real values
# =============================================================================

# --- Domain ---
DOMAIN=marley.yourdomain.com

# --- Supabase (hosted PostgreSQL + Realtime) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- API Authentication ---
# Generate with: openssl rand -hex 32
API_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# --- Worker API URL (internal Docker network) ---
NEXT_PUBLIC_WORKER_API_URL=http://worker-api:8000

# --- CORS (comma-separated origins allowed to call the worker API) ---
CORS_ORIGINS=https://marley.yourdomain.com

# --- Redis (internal — no need to change) ---
REDIS_URL=redis://redis:6379/0
